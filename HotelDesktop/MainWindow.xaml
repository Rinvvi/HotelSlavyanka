<Window x:Class="HotelDesktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:HotelDesktop"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <TextBlock x:Name="___Без_имени_" HorizontalAlignment="Left" Margin="245,166,0,0" TextWrapping="Wrap" Text="Логин:" VerticalAlignment="Top" FontSize="20"/>
        <TextBox x:Name="LoginTextBox" HorizontalAlignment="Left" Margin="337,164,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="120" RenderTransformOrigin="0.499,0.421" FontSize="20"/>
        <TextBlock HorizontalAlignment="Left" Margin="245,208,0,0" TextWrapping="Wrap" Text="Пароль:" VerticalAlignment="Top" FontSize="20"/>
        <PasswordBox x:Name="PasswordInput" HorizontalAlignment="Left" Margin="337,206,0,0" VerticalAlignment="Top" Width="120" FontSize="20"/>
        <Button Content="Войти" HorizontalAlignment="Center" Margin="0,256,0,0" VerticalAlignment="Top" Click="Button_Click" FontSize="20"/>

    </Grid>
</Window>
